# Hanzo AI Build Platform - Production Environment Configuration
# Copy this file to .env.production and fill in your values

# Application
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://hanzo.app
NEXTAUTH_URL=https://hanzo.app
NEXTAUTH_SECRET=your-nextauth-secret-here-generate-with-openssl-rand-base64-32

# Database
DATABASE_URL=postgresql://hanzo:password@postgres:5432/hanzo_build
DB_USER=hanzo
DB_PASSWORD=your-secure-db-password
DB_NAME=hanzo_build

# Redis
REDIS_URL=redis://:your-redis-password@redis:6379
REDIS_PASSWORD=your-redis-password

# Hanzo IAM SSO (hanzo.id) — issuer is hanzo.id everywhere; a legacy host here
# splits JWKS/issuer validation between the browser SDK and the server BFF.
IAM_CLIENT_ID=your-iam-client-id
IAM_CLIENT_SECRET=your-iam-client-secret
IAM_ENDPOINT=https://hanzo.id

# Hanzo Commerce (replaces Stripe; commerce.hanzo.ai is the gateway)
HANZO_COMMERCE_API_URL=https://api.hanzo.ai/v1
HANZO_COMMERCE_API_KEY=your-commerce-api-key
HANZO_COMMERCE_WEBHOOK_SECRET=your-commerce-webhook-secret

# Hanzo Commerce STOREFRONT (the build->become-a-store flywheel).
# The storefront BFF (lib/store.ts, app/api/store/*) reads the org's real
# catalog/cart/checkout/orders from commerce. Org == tenant.
HANZO_COMMERCE_STORE_URL=https://commerce.hanzo.ai
# Per-org storefront `Published` key for public/logged-out browsing (KMS-injected).
# Leave empty to require a signed-in merchant (their IAM token is forwarded).
HANZO_COMMERCE_STOREFRONT_TOKEN=
# The deployed first-party store binding (org == IAM owner). When set, this
# deployment "is" that org's store. A per-project store config (Base row keyed
# by space_id) overrides this per request.
HANZO_STORE_ORG=
HANZO_STORE_ID=default
HANZO_STORE_CURRENCY=USD
HANZO_STORE_MODE=ecommerce

# AI Providers
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
TOGETHER_API_KEY=your-together-api-key

# Optional AI Providers
GROQ_API_KEY=your-groq-api-key
REPLICATE_API_TOKEN=your-replicate-token
COHERE_API_KEY=your-cohere-api-key

# Monitoring (Optional)
SENTRY_DSN=your-sentry-dsn
POSTHOG_KEY=your-posthog-key
POSTHOG_HOST=https://app.posthog.com

# Feature Flags
ENABLE_COMMERCE_BILLING=true
ENABLE_USAGE_TRACKING=true
ENABLE_ANALYTICS=true

# Security
ALLOWED_ORIGINS=https://hanzo.app,https://hanzo.ai
RATE_LIMIT_PER_MINUTE=100
MAX_UPLOAD_SIZE=10485760

# Logging
LOG_LEVEL=info
LOG_FORMAT=json