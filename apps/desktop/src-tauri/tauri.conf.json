{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Hanzo",
  "version": "0.1.0",
  "identifier": "com.hanzo.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev"
  },
  "app": {
    "windows": [
      {
        "title": "Hanzo",
        "width": 600,
        "height": 400,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons"
    ]
  }
}
