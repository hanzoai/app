    "remark-emoji": "^5.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "token.js": "^0.7.1",
