{
  "name": "@hanzo/desktop",
  "private": true,
  "version": "2.1.178",
  "type": "module",
  "description": "Hanzo - AI-powered assistant for all platforms",
  "author": "Hanzo Industries Inc",
  "license": "MIT",
  "homepage": "https://hanzo.app",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "dev:web": "vite",
    "build": "pnpm build:web && pnpm build:tauri",
    "build:web": "vite build",
    "build:tauri": "tauri build",
    "ios:init": "tauri ios init",
    "ios:dev": "tauri ios dev",
    "ios:build": "tauri ios build",
    "android:init": "tauri android init",
    "android:dev": "tauri android dev",
    "android:build": "tauri android build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run src/ts/__tests__/unit",
    "test:integration": "vitest run src/ts/__tests__/integration",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "MODE=test playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "./src/ts/__tests__/run-tests.sh",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "tsc --noEmit",
    "docs:dev": "docusaurus start",
    "docs:build": "docusaurus build",
    "docs:serve": "docusaurus serve",
    "docs:deploy": "docusaurus deploy",
    "docs:clear": "docusaurus clear",
    "docs:typedoc": "typedoc --out docs/api/generated src/ts",
    "docs:generate": "pnpm docs:typedoc && pnpm docs:build"
  },
  "dependencies": {
    "@hanzo/ui": "^5.3.43",
    "@hanzo/chat": "workspace:*",
    "@hanzo/launcher": "workspace:*",
    "@hanzo/ai": "workspace:*",
