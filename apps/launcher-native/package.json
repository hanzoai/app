{
  "name": "@hanzo/launcher-native",
  "private": true,
  "version": "0.1.0",
  "description": "Expo (iOS/Android/web) target for the @hanzo/gui launcher case study — the SAME @hanzo/launcher UI, native.",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "bundle:ios": "expo export --platform ios --output-dir dist-export",
    "bundle:android": "expo export --platform android --output-dir dist-export",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hanzo/launcher": "file:../../packages/launcher",
    "@hanzo/gui": "7.3.0",
    "@hanzogui/config": "7.3.0",
    "@hanzogui/core": "7.3.0",
    "@hanzogui/lucide-icons-2": "7.3.0",
    "expo": "^57.0.0",
    "expo-status-bar": "~3.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/react": "~19.2.0",
    "typescript": "~5.9.0"
  }
}
