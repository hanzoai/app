{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Hanzo Launcher",
  "version": "0.1.0",
  "identifier": "ai.hanzo.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hanzo Launcher",
        "width": 660,
        "height": 460,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true,
        "visible": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/32x32.png"
    ]
  }
}
