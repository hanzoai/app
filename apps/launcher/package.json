  "version": "0.1.0",
  "type": "module",
  "description": "Web + Tauri desktop target for the @hanzo/gui launcher case study. The Vite/react-native-web bundle is the web build AND the Tauri window frontend.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 1420",
