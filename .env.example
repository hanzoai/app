# Hanzo App Environment Configuration

# AI Provider Keys (at least one required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
TOGETHER_API_KEY=...

# Hanzo Services
HANZO_API_URL=https://api.hanzo.ai
HANZO_LLM_URL=http://localhost:4000

# Telemetry (@hanzo/event -> the ONE front door, POST api.hanzo.ai/v1/event).
# Authed users ride their IAM bearer automatically. Set a publishable ingest key
# (pk_..., provisioned via POST /v1/ingest/keys) to also accept telemetry from
# LOGGED-OUT marketing/public views (pageviews + errors). Optional; safe to ship
# in the browser bundle (write-only).
NEXT_PUBLIC_HANZO_INGEST_KEY=

# Development
DEBUG=false
LOG_LEVEL=info